{
  "name": "paymore-kiosk-log-agent",
  "version": "1.0.0",
  "description": "Production JavaScript Windows background log upload agent for Paymore Kiosk machines.",
  "license": "UNLICENSED",
  "author": "Paymore",
  "type": "module",
  "main": "src/index.js",
  "engines": {
    "node": ">=20.11.0"
  },
  "files": [
    "src",
    "config",
    "README.md"
  ],
  "scripts": {
    "dev": "node --watch src/index.js",
    "start": "node src/index.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "verify": "npm run format:check && npm run lint"
  },
  "dependencies": {
    "archiver": "^8.0.0",
    "fast-glob": "^3.3.3",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.30.1",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.30.1",
    "eslint-config-prettier": "^10.1.5",
    "globals": "^15.15.0",
    "prettier": "^3.6.2",
    "vitest": "^3.2.4"
  }
}
